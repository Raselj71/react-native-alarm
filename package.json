{
  "name": "@raselj5060/react-native-alarm",
  "version": "0.1.1",
  "description": "Generic exact-alarm scheduler with any-state sound playback",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "react-native": "src/index.ts",
  "scripts": {
    "build": "node internal/module_scripts/build.js",
    "clean": "node internal/module_scripts/clean.js",
    "lint": "eslint src/",
    "test": "node internal/module_scripts/test.js",
    "prepare": "node internal/module_scripts/prepare.js",
    "open:ios": "node internal/module_scripts/open-ios.js",
    "open:android": "node internal/module_scripts/open-android.js"
  },
  "keywords": [
    "react-native",
    "expo",
    "alarm",
    "alarmmanager",
    "notifications"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Raselj71/react-native-alarm"
  },
  "bugs": {
    "url": "https://github.com/Raselj71/react-native-alarm/issues"
  },
  "author": "Raselj71 <tasks@taskatask.com> (https://github.com/Raselj71)",
  "license": "MIT",
  "homepage": "https://github.com/Raselj71/react-native-alarm#readme",
  "files": [
    "build",
    "plugin/build",
    "app.plugin.js",
    "android",
    "ios",
    "src",
    "expo-module.config.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/jest": "^29.2.1",
    "@types/react": "~19.1.1",
    "babel-preset-expo": "~55.0.8",
    "eslint": "~9.39.4",
    "eslint-config-universe": "^15.0.3",
    "expo": "^56.0.3",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "prettier": "^3.0.0",
    "react-native": "0.82.1",
    "typescript": "^5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "roots": [
      "<rootDir>/src"
    ],
    "moduleNameMapper": {
      "^expo/src/winter$": "<rootDir>/src/__mocks__/expo-winter-stub.js",
      "^expo/src/winter/(.*)$": "<rootDir>/src/__mocks__/expo-fetch-module.js"
    }
  },
  "peerDependencies": {
    "@expo/config-plugins": ">=8.0.0",
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
